// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  PATIENT
  ADMIN
}

enum AppointmentStatus {
  NEW
  AWAITING_PATIENT
  ARCHIVED
}

model User {
  id         String    @id @default(cuid())
  phone      String    @unique
  fullName   String?
  role       Role      @default(PATIENT)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  documents  PatientDocument[]
  appointmentRequests AppointmentRequest[]
}

/// Тип специалиста / услуги (справочник для записи на приём)
model SpecialistType {
  id            String               @id @default(cuid())
  name          String
  iconKey       String
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  appointments  AppointmentRequest[]
}

/// Заявка на приём из ЛК пациента
model AppointmentRequest {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialistTypeId String
  specialistType   SpecialistType    @relation(fields: [specialistTypeId], references: [id], onDelete: Restrict)
  /// Предпочитаемая дата YYYY-MM-DD
  date             String
  /// Интервал часа, напр. "09:00-10:00"
  timeSlot         String
  status           AppointmentStatus @default(NEW)
  /// Согласованная дата (пометка админа), YYYY-MM-DD
  adminDate        String?
  /// Согласованное время (пометка админа), HH:mm
  adminTime        String?
  createdAt        DateTime          @default(now())
}

model PatientDocument {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName   String
  /// Относительный путь от каталога загрузок (userId/fileId-name)
  storedPath     String
  mimeType       String?
  size           Int
  uploadedById   String?
  createdAt      DateTime @default(now())
}

/// Ожидание звонка SMS.ru callcheck; удаляется после успеха или истечения TTL
model PendingAuth {
  id        String   @id @default(cuid())
  checkId   String   @unique
  phone     String
  ipHash    String?
  /// Установлено webhook SMS.ru (дополнительно к опросу status)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

/// Простой учёт лимитов запросов (IP / телефон) в окне времени
model RateLimitBucket {
  id        String   @id
  count     Int      @default(0)
  windowEnd DateTime
}
