// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  PATIENT
  ADMIN
}

model User {
  id         String    @id @default(cuid())
  phone      String    @unique
  role       Role      @default(PATIENT)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
}

/// Ожидание звонка SMS.ru callcheck; удаляется после успеха или истечения TTL
model PendingAuth {
  id        String   @id @default(cuid())
  checkId   String   @unique
  phone     String
  ipHash    String?
  /// Установлено webhook SMS.ru (дополнительно к опросу status)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

/// Простой учёт лимитов запросов (IP / телефон) в окне времени
model RateLimitBucket {
  id        String   @id
  count     Int      @default(0)
  windowEnd DateTime
}
